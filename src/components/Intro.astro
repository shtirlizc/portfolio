---
import profilePicture from "../assets/profile.jpg";

interface Props {
  name: string;
  subtitle: string;
  summary: string;
}

const { name, subtitle, summary } = Astro.props;

const facts = [
  "12+ лет опыта",
  "React / Next.js / Angular",
  "UI-библиотеки и дизайн-системы",
];
---

<section class="intro">
  <div class="content">
    <div class="text">
      <p class="eyebrow">Frontend-разработчик</p>
      <h1>{name}</h1>
      <p class="subtitle">{subtitle}</p>
      <p class="summary">{summary}</p>
      <div class="actions" aria-label="Основные действия">
        <a class="button primary" href="#contacts">Связаться</a>
        <a class="button secondary" href="#works">Примеры работ</a>
      </div>
    </div>
    <div class="portrait">
      <img src={profilePicture.src} alt="Марат Сарваров" class="pfp" />
      <ul class="facts" aria-label="Ключевые факты">
        {facts.map((fact) => <li>{fact}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .intro {
    padding: 7rem 1.5rem 5rem;
  }

  .content {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    align-items: center;
    gap: 4rem;
    max-width: 1080px;
    margin: 0 auto;
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  h1 {
    color: var(--color-ink);
    font-size: 4.25rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.98;
    margin-bottom: 1.25rem;
  }

  .subtitle {
    color: var(--color-ink);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.35;
    max-width: 720px;
    margin-bottom: 1rem;
  }

  .summary {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 680px;
    margin-bottom: 2rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button {
    align-items: center;
    border-radius: 8px;
    display: inline-flex;
    font-size: 1rem;
    font-weight: 700;
    justify-content: center;
    min-height: 48px;
    padding: 0.75rem 1.1rem;
    text-decoration: none;
  }

  .primary {
    background: var(--color-accent);
    color: white;
  }

  .secondary {
    border: 1px solid var(--color-line);
    color: var(--color-ink);
    background: var(--color-panel);
  }

  .portrait {
    background: var(--color-panel);
    border: 1px solid var(--color-line);
    border-radius: 8px;
    padding: 1rem;
  }

  .pfp {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 8px;
  }

  .facts {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin-top: 1rem;
  }

  .facts li {
    background: var(--color-panel-alt);
    border-radius: 8px;
    color: var(--color-ink);
    font-weight: 600;
    padding: 0.8rem 0.9rem;
  }

  @media (max-width: 860px) {
    .intro {
      padding: 4rem 1rem;
    }

    .content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    h1 {
      font-size: 3.1rem;
    }

    .subtitle {
      font-size: 1.15rem;
    }
  }

  @media (max-width: 420px) {
    h1 {
      font-size: 2.55rem;
    }
  }
</style>
