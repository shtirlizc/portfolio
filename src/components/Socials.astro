---
const contacts = [
  {
    label: "Email",
    value: "shtirlizc@gmail.com",
    url: "mailto:shtirlizc@gmail.com",
    note: "предпочитаемый способ связи",
  },
  {
    label: "Telegram",
    value: "@shtirlizc",
    url: "https://t.me/shtirlizc",
    note: "быстрые сообщения",
  },
  {
    label: "Телефон",
    value: "+7 917 402-24-24",
    url: "tel:+79174022424",
    note: "Уфа, удаленно или гибрид",
  },
];
---

<section class="contacts" id="contacts" aria-labelledby="contacts-title">
  <div class="content">
    <div class="heading">
      <p class="eyebrow">Контакты</p>
      <h2 id="contacts-title">Готов обсудить frontend-задачи</h2>
      <p>
        Пишите в Telegram или на email. Контакты открыты для проектной работы,
        частичной и полной занятости.
      </p>
    </div>
    <div class="contact-links">
      {
        contacts.map((contact) => (
          <a href={contact.url} class="contact-link">
            <span class="label">{contact.label}</span>
            <span class="value">{contact.value}</span>
            <span class="note">{contact.note}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contacts {
    background: var(--color-accent-strong);
    color: white;
    padding: 5rem 1.5rem;
  }

  .content {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 3rem;
    max-width: 1080px;
    margin: 0 auto;
  }

  .heading {
    max-width: 560px;
  }

  .eyebrow {
    color: var(--color-mint);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  h2 {
    font-size: 3rem;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.05rem;
  }

  .contact-links {
    display: grid;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    min-height: 112px;
    flex-direction: column;
    justify-content: center;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 8px;
    color: white;
    padding: 1rem 1.2rem;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .contact-link:hover {
    background: rgba(255, 255, 255, 0.14);
    transform: translateY(-2px);
  }

  .label {
    color: var(--color-mint);
    font-size: 0.88rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .value {
    font-size: 1.25rem;
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .note {
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0.3rem;
  }

  @media (max-width: 760px) {
    .contacts {
      padding: 4rem 1rem;
    }

    .content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    h2 {
      font-size: 2.1rem;
    }

    .contact-link {
      min-height: 104px;
    }
  }
</style>
