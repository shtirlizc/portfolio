---
import project1 from "../assets/1.png";
import project2 from "../assets/2.png";
import project3 from "../assets/3.png";
import project4 from "../assets/4.png";
import project5 from "../assets/5.png";
import project6 from "../assets/6.png";

const projects = [
  {
    title: "Лендинг исследования от Сетки и hh.ru",
    description: "Целью разработки была адаптивная, семантичная верстка с хорошим перфомансом",
    stack: ['Astro'],
    url: "https://hrbrand.setka.ru/survey2026/",
    image: project1.src,
  },
  {
    title: "Stiki",
    description: "Моей задачей в проекте было привести визуал в полное соответствие с макетами и исправление багов",
    stack: ['Next.js', 'Pixel perfect'],
    url: "https://stiki.ru/",
    image: project2.src,
  },
  {
    title: "ИЖС Уфа",
    description: "Разработал весь цикл: рисование протипов по ТЗ, выбор стека, проектирование БД, верстка, интеграция, деплой",
    stack: ['Next.js', 'Supabase', 'Dokploy'],
    url: "https://doma102.ru/houses",
    image: project3.src,
  },
  {
    title: "Mental help",
    description: "Сайт центр психологического консультирования со сбором обратный звонков, блогом и админкой на Modx",
    stack: ['Modx', 'Адаптивная верстка', 'Кроссбраузерная верстка'],
    url: "https://mental-help.info/",
    image: project4.src,
  },
  {
    title: "Welldesk",
    description: "Требовался лендинг с блогом. реализовал его на Astro Content-first подходом. Сайт находится на иностранном хостинге, доступен только с ВПН",
    stack: ['Astro', 'Content-first подход', 'Cloudflare DB'],
    url: "https://welldesk.io/",
    image: project5.src,
  },
  {
    title: "Petrolance",
    description: "Требовался лендинг с обратной связью. (Сайт находится на иностранном хостинге, доступен только с ВПН)",
    stack: ['Astro'],
    url: "https://petrolance.com/",
    image: project6.src,
  },
];
---

<section class="projects-section" id="works" aria-labelledby="works-title">
  <div class="content">
    <p class="eyebrow">Работы</p>
    <h2 id="works-title" class="section-title">Примеры работ</h2>
    <p class="section-intro">
      Описания кейсов, ссылки на проекты и короткий контекст по
      работам.
    </p>
    <div class="projects">
      {
        projects.map((project) => (
          <article class="project-card">
            <div class="project-media">
              {project.image ? (
                <img
                  src={project.image}
                  alt={`Скриншот проекта ${project.title}`}
                />
              ) : (
                <div class="project-placeholder">
                  <span>Фото проекта</span>
                  <small>Скриншот или обложка кейса</small>
                </div>
              )}
            </div>
            <div class="project-body">
              <h3>{project.title}</h3>
              {project.description && <p>{project.description}</p>}
              {project.stack.length > 0 && (
                <ul aria-label={`Стек проекта ${project.title}`}>
                  {project.stack.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
              {project.url ? (
                <a
                  class="project-link"
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Открыть
                </a>
              ) : (
                <span class="project-link muted">
                  Ссылка появится после публикации
                </span>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 5rem 1.5rem;
  }

  .content {
    max-width: 1080px;
    margin: 0 auto;
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .section-title {
    color: var(--color-ink);
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .section-intro {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 720px;
    margin-bottom: 2rem;
  }

  .projects {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    background: var(--color-panel);
    border: 1px solid var(--color-line);
    border-radius: 8px;
    overflow: hidden;
  }

  .project-media {
    aspect-ratio: 16 / 10;
    background: var(--color-panel-alt);
  }

  .project-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-placeholder {
    display: grid;
    place-content: center;
    height: 100%;
    padding: 1.5rem;
    text-align: center;
  }

  .project-placeholder span {
    color: var(--color-ink);
    font-weight: 700;
  }

  .project-placeholder small {
    color: var(--color-muted);
    margin-top: 0.25rem;
  }

  .project-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.2rem;
  }

  h3 {
    color: var(--color-ink);
    font-size: 1.2rem;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  p {
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin-top: auto;
  }

  li {
    background: var(--color-panel-alt);
    border: 1px solid var(--color-line);
    border-radius: 8px;
    color: var(--color-accent-strong);
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 0.4rem 0.55rem;
  }

  .project-link {
    align-items: center;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    color: var(--color-ink);
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    margin-top: 1rem;
    min-height: 42px;
    padding: 0.6rem 0.8rem;
    text-decoration: none;
  }

  .project-link:not(.muted) {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }

  .muted {
    color: var(--color-muted);
  }

  @media (max-width: 960px) {
    .projects {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .projects-section {
      padding: 4rem 1rem;
    }

    .section-title {
      font-size: 2.1rem;
    }
  }
</style>
