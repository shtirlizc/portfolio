---
import Layout from "../layouts/Layout.astro";
import Experience from "../components/Experience.astro";
import Intro from "../components/Intro.astro";
import Projects from "../components/Projects.astro";
import Skills from "../components/Skills.astro";
import Socials from "../components/Socials.astro";

const page = {
  name: "Марат Сарваров",
  title: "Марат Сарваров - Frontend-разработчик",
  subtitle:
    "Frontend-разработчик с 12+ годами опыта в SPA-приложениях, дизайн-системах и продуктовых интерфейсах.",
  summary:
    "Работаю с React, Next.js, Angular и TypeScript. Помогаю командам собирать стабильные интерфейсы, развивать UI-библиотеки и аккуратно связывать frontend с данными.",
  description:
    "Портфолио Марата Сарварова, frontend-разработчика из Уфы с опытом в React, Next.js, Angular, TypeScript, SPA и дизайн-системах.",
};
---

<Layout title={page.title} description={page.description}>
  <main>
    <Intro name={page.name} subtitle={page.subtitle} summary={page.summary} />
    <Skills />
    <Experience />
    <Projects />
    <Socials />
  </main>
</Layout>
